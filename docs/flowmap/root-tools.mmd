flowchart LR
%% root flowmapBuildspec

%% ---- tooling subsystems (containers; members live in tools/**/*.flowmap.mmd fragments) ----
%% fm:meta flowmapBuildspec name=buildspec
%% fm:meta flowmapBuildspec desc=buildspec pipeline: parse, extract, gate — turns code into a checkable spec and enforces code equals map
%% fm:meta flowmapIntegrity name=integrity
%% fm:meta flowmapIntegrity desc=map-integrity chain: bundle, validate, lint, coverage, exports, edges — proves the map is true and complete
%% fm:meta flowmapUnderstand name=understand
%% fm:meta flowmapUnderstand desc=understand: onboard, comprehension quiz, trust tiers — a verifiable 0-context handover
%% fm:meta flowmapContinuity name=continuity
%% fm:meta flowmapContinuity desc=continuity: verified work-state, computed roadmap, handoff freshness — resume without prose
%% fm:meta flowmapPlanApprove name=plan+approve
%% fm:meta flowmapPlanApprove desc=plan review and approval gates: coherence check, dry-run certificate, and the build-bundle mint
%% fm:meta flowmapContractSpine name=contract-spine
%% fm:meta flowmapContractSpine desc=subagent contract spine: per-change packet, verdict, determinism harness, waves and the orchestrator

%% ---- app-surface boundary (the src/ counterparts the tooling reuses/enforces) ----
%% fm:meta mermaid name=mermaid
%% fm:meta mermaid desc=app serializer/parser the tooling parser must agree with (two-parser conformance A3)
%% fm:meta frontmatter name=frontmatter
%% fm:meta frontmatter desc=app frontmatter model the tooling parser and skeleton mirror
%% fm:meta state name=state
%% fm:meta state desc=app model and geometry helpers the tooling mirrors and runs acceptance cases against
%% fm:meta files name=files
%% fm:meta files desc=app file IO that consumes the bodies.json the extractor writes
%% fm:meta diff name=diff
%% fm:meta diff desc=app semantic diff whose engine the tooling diff-core shares
%% fm:meta slice name=slice
%% fm:meta slice desc=app neighbourhood slice whose engine the tooling slice-core mirrors
%% fm:meta plan name=plan
%% fm:meta plan desc=app plan overlay model the tooling plan/cert/contract tools parallel and route into

%% kind flowmapBuildspec module
%% kind flowmapIntegrity module
%% kind flowmapUnderstand module
%% kind flowmapContinuity module
%% kind flowmapPlanApprove module
%% kind flowmapContractSpine module
%% kind mermaid module
%% kind frontmatter module
%% kind state module
%% kind files module
%% kind diff module
%% kind slice module
%% kind plan module

  flowmapBuildspec["buildspec"]
  flowmapIntegrity["integrity"]
  flowmapUnderstand["understand"]
  flowmapContinuity["continuity"]
  flowmapPlanApprove["plan+approve"]
  flowmapContractSpine["contract-spine"]

  subgraph AppSurface ["app surface (src/)"]
    mermaid["mermaid"]
    frontmatter["frontmatter"]
    state["state"]
    files["files"]
    diff["diff"]
    slice["slice"]
    plan["plan"]
  end

  %% ---- subsystem-level flow (the loop) ----
  flowmapUnderstand -->|onboard shells verify chain| flowmapIntegrity
  flowmapUnderstand -->|onboard shows roadmap| flowmapContinuity
  flowmapIntegrity -.->|gate + extract| flowmapBuildspec
  flowmapContinuity -.->|status reuses extract| flowmapBuildspec
  flowmapPlanApprove -.->|cert/approve reuse pipeline| flowmapBuildspec
  flowmapContractSpine -.->|verify/waves shell status| flowmapContinuity
  flowmapContractSpine -.->|contract uses plan-check| flowmapPlanApprove
  flowmapContractSpine -.->|contract/verify reuse acceptance| flowmapBuildspec

  %% ---- tooling -> app surface (the blast radius) ----
  flowmapBuildspec -.->|two-parser conformance| mermaid
  flowmapBuildspec -.->|mirrors helpers| state
  flowmapBuildspec -.->|writes bodies.json| files
  flowmapPlanApprove -.->|parallels core/plan| plan
  flowmapContractSpine -.->|downstreamCone| plan
